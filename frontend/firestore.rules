rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin is either the bootstrapped developer or has the admin role in the database
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'nrakeshkumar36@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION HELPER BLUEPRINTS ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.email is string &&
             data.role is string && (data.role == 'student' || data.role == 'admin');
    }

    function isValidTestAttempt(data) {
      return data.keys().hasAll(['id', 'userId', 'testId', 'answers', 'score', 'percentage', 'accuracy', 'correctCount', 'wrongCount', 'unattemptedCount', 'timeTakenSeconds', 'submittedAt']) &&
             data.userId == request.auth.uid &&
             data.testId is string &&
             data.score is number &&
             data.percentage is number &&
             data.accuracy is number &&
             data.correctCount is number &&
             data.wrongCount is number &&
             data.unattemptedCount is number &&
             data.timeTakenSeconds is number;
    }

    // --- COLLECTION MATCH RULES ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      // Allow user creation on signup: can only register as student unless bootstrapped email
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'student' || 
        (incoming().role == 'admin' && request.auth.token.email == 'nrakeshkumar36@gmail.com')
      );
      
      // Allow users to update their profile details but prevent student role from upgrading to admin
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == existing().role || isAdmin()
      );
      
      allow delete: if isAdmin();
    }

    // ENTRANCE EXAMS
    match /entranceExams/{examId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // COMPETITIVE EXAMS
    match /competitiveExams/{examId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // SUBJECTS
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // CHAPTERS
    match /chapters/{chapterId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // TIMETABLES
    match /timetables/{timetableId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // STUDY MATERIALS
    match /studyMaterials/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // QUESTIONS BANK
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // TESTS
    match /tests/{testId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // TEST ATTEMPTS
    match /testAttempts/{attemptId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTestAttempt(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidTestAttempt(incoming());
      allow delete: if isAdmin();
    }

    // ANNOUNCEMENTS
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
